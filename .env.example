# Solana RPC (Helius). Free tier (10 RPS) ok for sampling; Developer (50 RPS) or higher
# recommended for any uncapped pull. https://helius.dev/pricing
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Base RPC. Public works for sampling; Alchemy free tier covers eth_getLogs at scale.
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon RPC (used for spot-checking the Polygon facilitator wallets only).
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Dune API key. The rigorous-comparison pipeline uses Dune as the global ground truth
# (Phase 1 SQL aggregates 180M+ x402 USDC transfers server-side). Plus tier or higher
# recommended for the full export; free tier sufficient for the per-day rollup.
# Get a key: https://dune.com/settings/api
DUNE_API_KEY=

# Optional Bitquery key (cross-validation only)
BITQUERY_API_KEY=
